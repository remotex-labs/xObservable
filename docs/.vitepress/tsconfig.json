{
    "compilerOptions": {
        "strict": true,
        "noEmit": true,
        "target": "ESNext",
        "module": "ESNext",
        "skipLibCheck": true,
        "esModuleInterop": true,
        "moduleResolution": "bundler",
        "resolveJsonModule": true,
        "lib": [
            "DOM",
            "ESNext"
        ],
        "types": [
            "node"
        ],
        "paths": {
            "vue": [
                "../../node_modules/.pnpm/node_modules/vue"
            ],
            "@vue/runtime-core": [
                "../../node_modules/.pnpm/node_modules/@vue/runtime-core"
            ]
        }
    },
    "include": [
        "**/*.ts",
        "**/*.vue",
        "env.d.ts"
    ],
    "exclude": [
        "dist",
        "cache"
    ]
}
